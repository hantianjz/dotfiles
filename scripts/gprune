#!/bin/sh
# Prune local branches whose remote tracking branch has been deleted.
# Works on Linux and macOS, under bash, zsh, fish (invoked via /bin/sh).

set -eu

git fetch --prune

# Find local branches whose upstream is gone
gone_branches=$(git branch -vv | grep ': gone]' | awk '{print $1}')

if [ -z "$gone_branches" ]; then
  exit 0
fi

echo "$gone_branches" | while IFS= read -r branch; do
  git branch -D "$branch"
done
